DATABASE_URL=sqlite:///./data/carbonlens.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000
OPENAI_CB_FAILURES=3
OPENAI_CB_COOLDOWN_SECONDS=60
DOC_MAX_PAGES=5
DOC_RENDER_DPI=144
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PDF_OUTPUT_DIR=./data/reports
LOG_LEVEL=INFO
JWT_SECRET=dev-secret-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# Polygon anchoring. Default is "simulated" so the demo works without a
# funded wallet. For real anchoring, deploy contracts/src/CarbonLensAnchor.sol
# to Amoy (see contracts/README.md), then flip CHAIN_MODE and fill in the rest.
CHAIN_MODE=simulated
POLYGON_RPC_URL=
ANCHOR_CONTRACT_ADDRESS=
ANCHOR_PRIVATE_KEY=
ANCHOR_CHAIN_ID=80002
ANCHOR_EXPLORER_URL=https://amoy.polygonscan.com
